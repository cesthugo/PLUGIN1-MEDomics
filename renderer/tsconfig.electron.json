{
  // TypeScript config to compile electron/main.ts and electron/preload.ts
  // to CommonJS (required for Electron's Node.js process).
  //
  // The compiled files go into electron-dist/ — a package.json with
  // "type": "commonjs" is generated there by the build:electron-main script to
  // work around the "type": "module" of the root package.json.
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "CommonJS",
    "moduleResolution": "node",
    "outDir":           "electron-dist",
    "rootDir":          "electron",
    "strict":           true,
    "skipLibCheck":     true,
    "esModuleInterop":  true,
    "noEmit":           false
  },
  "include": ["electron"]
}
