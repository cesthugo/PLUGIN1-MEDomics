{
  "name": "starhe-plugin",
  "version": "0.7.0-beta.4",
  "description": "STARHE — Plugin MEDomics (détection et évaluation du risque sur DICOM échographique hépatique)",
  "author": {
    "name": "MEDomics-UdeS",
    "email": "medomics@usherbrooke.ca"
  },
  "homepage": "https://github.com/cesthugo/PLUGIN1-MEDomics",
  "repository": "github:cesthugo/PLUGIN1-MEDomics",
  "private": true,
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "dev:electron": "concurrently --kill-others -n vite,electron -c cyan,yellow \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "tsc --noEmit && vite build",
    "build:electron-main": "node -e \"const fs=require('fs');fs.mkdirSync('electron-dist',{recursive:true});fs.writeFileSync('electron-dist/package.json',JSON.stringify({type:'commonjs'}));fs.copyFileSync('electron/splash.html','electron-dist/splash.html')\" && tsc -p tsconfig.electron.json",
    "build:electron": "npm run build:renderer && npm run build:electron-main",
    "electron:pack": "npm run build:electron && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.medomics.starhe-plugin",
    "productName": "STARHE",
    "artifactName": "STARHE-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "!**/.DS_Store",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "build-resources/weasis-dcm2png",
        "to": "weasis-dcm2png",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.medical",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extraResources": [
        { "from": "build-resources/go-server/go-server-mac-${arch}", "to": "go_server/go_server" },
        { "from": "build-resources/starhe_worker", "to": "starhe_worker" },
        { "from": "build-resources/jre-mac-${arch}", "to": "jre" }
      ],
      "target": [
        { "target": "dmg" },
        { "target": "zip" }
      ]
    },
    "dmg": {
      "artifactName": "STARHE-${version}-mac-${arch}.${ext}",
      "title": "STARHE ${version}"
    },
    "linux": {
      "category": "Science",
      "icon": "build-resources/icon.png",
      "synopsis": "STARHE — Plugin MEDomics (DICOM hépatique)",
      "maintainer": "MEDomics-UdeS <medomics@usherbrooke.ca>",
      "extraResources": [
        { "from": "build-resources/go-server/go-server-linux-x64", "to": "go_server/go_server" },
        { "from": "build-resources/starhe_worker", "to": "starhe_worker" },
        { "from": "build-resources/jre-linux-${arch}", "to": "jre" }
      ],
      "target": [
        { "target": "deb", "arch": ["x64"] }
      ]
    },
    "win": {
      "extraResources": [
        { "from": "build-resources/go-server/go-server-win-x64.exe", "to": "go_server/go_server.exe" },
        { "from": "build-resources/starhe_worker", "to": "starhe_worker" },
        { "from": "build-resources/jre-win-${arch}", "to": "jre" }
      ],
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "STARHE-${version}-win-${arch}.${ext}"
    }
  }
}
