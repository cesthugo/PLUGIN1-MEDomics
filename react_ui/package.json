{
  "name": "starhe-plugin-react-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "dev:electron": "concurrently --kill-others -n vite,electron -c cyan,yellow \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "tsc --noEmit && vite build",
    "build:electron-main": "node -e \"const fs=require('fs');fs.mkdirSync('electron-dist',{recursive:true});fs.writeFileSync('electron-dist/package.json',JSON.stringify({type:'commonjs'}))\" && tsc -p tsconfig.electron.json",
    "build:electron": "npm run build:renderer && npm run build:electron-main",
    "electron:pack": "npm run build:electron && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.medomics.starhe-plugin",
    "productName": "STARHE — MEDomics",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "!**/.DS_Store"
    ],
    "extraResources": [
      {
        "from": "../go_server/go_server",
        "to": "go_server/go_server"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.medical"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
