# ── Medical data (.dcm files, potentially heavy / sensitive) ─────────────────
data/

# ── Local diagnostic scripts (out of the repo, for occasional use) ────────────
diagnostic_crossplatform.py
diagnostic_*.py

# ── Assistant / internal notes (not distributed) ──────────────────────────────
CLAUDE.md
.claude/
.cursorrules
memory/

# ── Compiled binaries ─────────────────────────────────────────────────────────
*.exe
# Go binaries (compiled locally, OS-specific)
go_server/go_server
go_server/starhe_server

# ── Python virtual environments ───────────────────────────────────────────────
.venv/
venv/
__pycache__/
*.py[cod]

# ── AI model weights (heavy binaries — download via download_models.py) ──
pythonCode/modules/starhe_plugin/models/*.pth
# The mmdet configs (.py) are lightweight and versioned:
!pythonCode/modules/starhe_plugin/models/*.py

# ── Pipeline temporary files ──────────────────────────────────────────────────
pythonCode/modules/starhe_plugin/temp/

# ── Tool-generated directories ────────────────────────────────────────────────
*.egg-info/
dist/
build/
.pytest_cache/
logs/

# ── Node.js (React/Vite dependencies – OS-specific binaries, never commit) ──
node_modules/
renderer/dist/

# ── Electron build artifacts (generated by npm run electron:pack) ─────────────
renderer/electron-dist/
renderer/release/

# ── Compiled resources in renderer/build-resources/ ───────────────────────────
# Temurin JREs downloaded by scripts/fetch_jre.sh (~130 MB per platform)
renderer/build-resources/jre-*/
# PyInstaller bundle (~500 MB, rebuild via `make build-worker` on each target OS)
renderer/build-resources/starhe_worker/
# weasis-dcm2png JAR (copied from third_party/weasis-dcm2png/dist after the Maven build)
renderer/build-resources/weasis-dcm2png/
# go-server/ is NOT gitignored: the 4 cross-compiled binaries (~55 MB total)
# are committed so that `git clone` works directly on mac/linux/win.
# Regenerate with `make cross-compile` if the Go code changes.

# ── prepUS build artifacts (generated by pip install / python setup.py build) ─
third_party/prepUS/build/

# ── IDE & OS ───────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
Thumbs.db
.DS_Store
