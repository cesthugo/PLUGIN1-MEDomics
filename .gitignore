# ── Données médicales (fichiers .dcm potentiellement lourds / sensibles) ──────
data/

# ── Binaires compilés ─────────────────────────────────────────────────────────
*.exe

# ── Environnements virtuels Python ────────────────────────────────────────────
.venv/
venv/
__pycache__/
*.py[cod]

# ── Poids des modèles IA (binaires lourds — télécharger via download_models.py) ──
pythonCode/modules/starhe_plugin/models/*.pth
# Les configs mmdet (.py) sont légères et versionnées :
!pythonCode/modules/starhe_plugin/models/*.py

# ── Fichiers temporaires du pipeline ──────────────────────────────────────────
pythonCode/modules/starhe_plugin/temp/

# ── Dossiers générés par les outils ───────────────────────────────────────────
*.egg-info/
dist/
build/
.pytest_cache/

# ── Build artifacts de prepUS (généré par pip install / python setup.py build) ─
third_party/prepUS/build/

# ── IDE & OS ───────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
Thumbs.db
.DS_Store
