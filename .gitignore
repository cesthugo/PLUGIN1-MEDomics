# ── Données médicales (fichiers .dcm potentiellement lourds / sensibles) ──────
data/

# ── Scripts de diagnostic locaux (hors dépôt, à usage ponctuel) ───────────────
diagnostic_crossplatform.py
diagnostic_*.py

# ── Binaires compilés ─────────────────────────────────────────────────────────
*.exe
# Binaires Go (compilés localement, spécifiques à l'OS)
go_server/go_server
go_server/starhe_server

# ── Environnements virtuels Python ────────────────────────────────────────────
.venv/
venv/
__pycache__/
*.py[cod]

# ── Poids des modèles IA (binaires lourds — télécharger via download_models.py) ──
pythonCode/modules/starhe_plugin/models/*.pth
# Les configs mmdet (.py) sont légères et versionnées :
!pythonCode/modules/starhe_plugin/models/*.py

# ── Fichiers temporaires du pipeline ──────────────────────────────────────────
pythonCode/modules/starhe_plugin/temp/

# ── Dossiers générés par les outils ───────────────────────────────────────────
*.egg-info/
dist/
build/
.pytest_cache/
logs/

# ── Node.js (dépendances React/Vite – binaires spécifiques à l'OS, jamais commiter) ──
node_modules/
renderer/dist/

# ── Electron build artifacts (générés par npm run electron:pack) ──────────────
renderer/electron-dist/
renderer/release/

# ── Ressources compilées dans renderer/build-resources/ ───────────────────────
# JRE Temurin téléchargées par scripts/fetch_jre.sh (~130 MB par plateforme)
renderer/build-resources/jre-*/
# Bundle PyInstaller (~500 MB, rebuild via `make build-worker` sur chaque OS cible)
renderer/build-resources/starhe_worker/
# JAR weasis-dcm2png (copié depuis third_party/weasis-dcm2png/dist après build Maven)
renderer/build-resources/weasis-dcm2png/
# go-server/ N'EST PAS gitignored : les 4 binaires cross-compilés (~55 MB total)
# sont committés pour que `git clone` fonctionne directement sur mac/linux/win.
# Regénérer avec `make cross-compile` si le code Go change.

# ── Build artifacts de prepUS (généré par pip install / python setup.py build) ─
third_party/prepUS/build/

# ── IDE & OS ───────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
Thumbs.db
.DS_Store
